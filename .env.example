# ── Google GenAI (Gemini text + image) ─────────────────────────────
GEMINI_API_KEY=

# Model overrides (defaults are set in code; override here if needed)
# GEMINI_TEXT_MODEL=gemini-2.5-flash
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# ── Meta / Instagram Graph API ──────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
# Long-lived Instagram user access token per account (60-day, auto-refreshed)
IG_TOKEN_MIDNIGHTCOUPLEGAME=
IG_USER_ID_MIDNIGHTCOUPLEGAME=
# Phase 2:
# IG_TOKEN_GIRLSOFMIDNIGHT=
# IG_USER_ID_GIRLSOFMIDNIGHT=

# ── Telegram ────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Cloudflare R2 (S3-compatible) ───────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=praxis-media
# Public base URL of the bucket (r2.dev subdomain or custom domain)
R2_PUBLIC_BASE_URL=

# ── GitHub (secret rotation from token-refresh workflow) ────────────
# Fine-grained PAT, ONLY this repo, ONLY "Secrets: Read and write"
GH_PAT_SECRETS_WRITE=
GH_REPO=metinkaplaan/Praxis
