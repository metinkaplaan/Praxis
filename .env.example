# ── Google GenAI (Gemini text + image) ─────────────────────────────
GEMINI_API_KEY=

# Model overrides (defaults are set in code; override here if needed)
# GEMINI_TEXT_MODEL=gemini-2.5-flash
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# VEO_MODEL=veo-3.1-fast-generate-preview
# VEO_POLL_INTERVAL_MS=15000
# VEO_MAX_POLL_MS=600000
# VEO_RESOLUTION=1080p          # 720p if the model/region rejects 9:16+1080p
# VEO_DURATION_SEC=8

# ── Format rotation / learning (src/analytics/) ─────────────────────
# FORMAT_EXPLORATION_RATE=0.2   # epsilon-greedy exploration share
# FORMAT_MIN_SAMPLES=3          # samples needed before a format/combo is "trusted"
# INSIGHTS_MATURATION_DAYS=3    # days after publish before insights are collected (Wave 2)

# ── Content planner (src/planning/, Wave 4) ─────────────────────────
# PLANNER_EXPLORATION_RATE=0.2  # epsilon-greedy exploration share for topic/hook/goal picks

# ── QA / debug ───────────────────────────────────────────────────────
# FORCE_FORMAT=                 # single|carousel|reel — bypasses rotation for manual testing
# SLOT_INDEX=                   # 0-4 — set by content-cycle.yml per cron slot, looks up today's plan entry

# ── Meta / Instagram Graph API ──────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
# Long-lived Instagram user access token per account (60-day, auto-refreshed)
IG_TOKEN_MIDNIGHTCOUPLEGAME=
IG_USER_ID_MIDNIGHTCOUPLEGAME=
# Phase 2:
# IG_TOKEN_GIRLSOFMIDNIGHT=
# IG_USER_ID_GIRLSOFMIDNIGHT=

# ── Telegram ────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Cloudflare R2 (S3-compatible) ───────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=praxis-media
# Public base URL of the bucket (r2.dev subdomain or custom domain)
R2_PUBLIC_BASE_URL=

# ── GitHub (secret rotation from token-refresh workflow) ────────────
# Fine-grained PAT, ONLY this repo, ONLY "Secrets: Read and write"
GH_PAT_SECRETS_WRITE=
GH_REPO=metinkaplaan/Praxis
